# Redis
REDIS_URL=redis://redis:6379

# MinIO (used by the MinIO container and the S3 client)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# S3-compatible storage
# For Docker: point to the MinIO container. For production we can replace with S3/R2/Supabase real endpoint.
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=image-processor
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=3600

# API
MAX_FILE_SIZE=20971520
API_PORT=3000

# Frontend (only used during local dev, not Docker)
VITE_API_URL=http://localhost:3000
